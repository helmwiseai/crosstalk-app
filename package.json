{
  "name": "crosstalk-app",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "npm run -ws build",
    "dev:api": "npm --workspace @crosstalk/api run dev",
    "dev:web": "npm --workspace @crosstalk/web run dev",
    "check": "npm run -ws check",
    "test:e2e": "bash scripts/e2e-session-smoke.sh",
    "demo:text": "node scripts/demo-text.mjs"
  }
}
